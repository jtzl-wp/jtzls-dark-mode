{
  "name": "simple-dark-mode-assets",
  "version": "1.0.0",
  "description": "Simple Dark Mode plugin assets - CSS build system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:css && bun run hash:assets",
    "build:css": "postcss src/css/dark-mode-block.css -o build/css/dark-mode-block.min.css && postcss src/css/dark-mode-classic.css -o build/css/dark-mode-classic.min.css",
    "hash:assets": "bun run scripts/hash-assets.js",
    "build:prod": "bun run build",
    "dev": "bun run scripts/css-watch.js",
    "dev:css": "bun run scripts/css-watch.js",
    "watch": "bun run dev",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "chokidar": "^4.0.3",
    "cssnano": "^7.1.1",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.3.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
