{
	"name": "simple-dark-mode-assets",
	"version": "1.0.0",
	"description": "Simple Dark Mode plugin assets - CSS build system",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run build:css",
		"build:css": "postcss assets/src/css/dark-mode.css -o assets/dist/css/dark-mode.min.css",
		"build:prod": "bun run build",
		"dev": "bun run dev:css",
		"dev:css": "postcss assets/src/css/dark-mode.css -o assets/dist/css/dark-mode.min.css --watch",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:coverage": "vitest --run --coverage",
		"lint": "eslint assets/src --ext .js,.ts",
		"lint:fix": "eslint assets/src --ext .js,.ts --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^2.1.9",
		"autoprefixer": "^10.4.21",
		"cssnano": "^7.1.1",
		"esbuild": "^0.23.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.1.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.6",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.0",
		"postcss-import": "^16.1.1",
		"prettier": "^3.3.3",
		"vitest": "^2.1.8"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"lint-staged": {
		"*.{css,json,md,yml,yaml}": [
			"prettier --write"
		],
		"*.php": [
			"vendor/bin/phpcbf --standard=phpcs.xml --report=summary --"
		]
	}
}
